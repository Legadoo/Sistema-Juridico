generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model LawFirm {
  availabilityWindows AvailabilityWindow[]
  availabilitySlots   AvailabilitySlot[]
  appointments        Appointment[]

  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                User[]
  clients              Client[]
  processes            LegalProcess[]
  config               FirmConfig?
  paymentGatewayConfig PaymentGatewayConfig?
  charges              Charge[]
  recurringCharges     RecurringCharge[]     @relation("FirmRecurringCharges")
}

model FirmConfig {
  id                 String   @id @default(cuid())
  firmId             String   @unique
  maxClients         Int      @default(50)
  moduleDashboard    Boolean  @default(true)
  moduleClients      Boolean  @default(true)
  moduleProcesses    Boolean  @default(true)
  moduleDeadlines    Boolean  @default(true)
  moduleAppointments Boolean  @default(true)
  moduleAvailability Boolean  @default(true)
  moduleUsers        Boolean  @default(true)
  moduleCharges      Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  firm LawFirm @relation(fields: [firmId], references: [id], onDelete: Cascade)
}

model User {
  availabilityWindows AvailabilityWindow[] @relation("CreatedAvailabilityWindows")
  createdAppointments Appointment[]        @relation("CreatedAppointments")

  id                         String    @id @default(cuid())
  name                       String
  email                      String    @unique
  phone                      String?
  emailVerified              Boolean   @default(false)
  emailVerificationToken     String?
  emailVerificationExpiresAt DateTime?
  password                   String
  role                       String    @default("SECRETARY") // "MASTER" ou "SECRETARY"
  active                     Boolean   @default(true)
  onboardingStatus           String?   @default("PLAN_REQUIRED")
  selectedPlanId             String?
  selectedPlanNameSnapshot   String?

  firmId String?
  firm   LawFirm? @relation(fields: [firmId], references: [id], onDelete: Restrict)

  assignedClients   Client[]       @relation("AssignedClients")
  assignedProcesses LegalProcess[] @relation("AssignedProcesses")

  sessions Session[]

  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  createdCharges          Charge[]
  createdRecurringCharges RecurringCharge[]  @relation("UserCreatedRecurringCharges")
  saasSubscriptions       SaaSSubscription[]
  selectedPlan            PublicPlan?        @relation("UserSelectedPlan", fields: [selectedPlanId], references: [id])

  @@index([firmId])
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  expiresAt DateTime

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Client {
  appointments Appointment[]

  id         String   @id @default(cuid())
  name       String
  document   String // CPF ou CNPJ (somente numeros)
  phone      String?
  email      String?
  accessCode String // codigo do cliente
  notes      String?
  archived   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  firmId String
  firm   LawFirm @relation(fields: [firmId], references: [id], onDelete: Cascade)

  assignedLawyerId String?
  assignedLawyer   User?   @relation("AssignedClients", fields: [assignedLawyerId], references: [id], onDelete: SetNull)

  processes              LegalProcess[]
  charges                Charge[]
  clientRecurringCharges RecurringCharge[] @relation("ClientRecurringCharges")

  @@unique([firmId, document])
  @@index([firmId])
  @@index([assignedLawyerId])
}

model LegalProcess {
  id        String    @id @default(cuid())
  cnj       String
  tribunal  String?
  vara      String?
  status    String    @default("ACTIVE") // "ACTIVE" ou "ARCHIVED"
  startDate DateTime?
  notes     String?
  archived  Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  firmId String
  firm   LawFirm @relation(fields: [firmId], references: [id], onDelete: Cascade)

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  assignedLawyerId String?
  assignedLawyer   User?   @relation("AssignedProcesses", fields: [assignedLawyerId], references: [id], onDelete: SetNull)

  updates   ProcessUpdate[]
  deadlines Deadline[]
  charges   Charge[]

  @@unique([firmId, cnj])
  @@index([firmId])
  @@index([clientId])
  @@index([assignedLawyerId])
}

model ProcessUpdate {
  id              String   @id @default(cuid())
  date            DateTime @default(now())
  text            String
  visibleToClient Boolean  @default(true)
  createdAt       DateTime @default(now())

  processId String
  process   LegalProcess @relation(fields: [processId], references: [id], onDelete: Cascade)

  @@index([processId])
}

model Deadline {
  id          String   @id @default(cuid())
  title       String
  description String?
  dueDate     DateTime
  priority    String   @default("MEDIUM") // "LOW" | "MEDIUM" | "HIGH"
  done        Boolean  @default(false)
  createdAt   DateTime @default(now())

  processId String
  process   LegalProcess @relation(fields: [processId], references: [id], onDelete: Cascade)

  @@index([processId])
}

model SystemConfig {
  id         String   @id @default("global")
  maxClients Int      @default(50)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Appointment {
  id              String   @id @default(cuid())
  scheduledAt     DateTime
  durationMinutes Int      @default(60)
  status          String   @default("AGENDADO") // SCHEDULED | CONFIRMED | CANCELLED | COMPLETED
  source          String   @default("INTERNAL") // INTERNAL | PUBLIC
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  firmId String
  firm   LawFirm @relation(fields: [firmId], references: [id], onDelete: Cascade)

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  availabilitySlotId String? @unique

  availabilitySlot AvailabilitySlot? @relation(fields: [availabilitySlotId], references: [id], onDelete: SetNull)

  createdByUserId String
  createdByUser   User   @relation("CreatedAppointments", fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([firmId])
  @@index([clientId])
  @@index([createdByUserId])
  @@index([scheduledAt])
}

model AvailabilityWindow {
  id                  String   @id @default(cuid())
  date                DateTime
  startTime           String
  endTime             String
  slotIntervalMinutes Int
  isActive            Boolean  @default(true)
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  firmId String
  firm   LawFirm @relation(fields: [firmId], references: [id], onDelete: Cascade)

  createdByUserId String
  createdByUser   User   @relation("CreatedAvailabilityWindows", fields: [createdByUserId], references: [id], onDelete: Restrict)

  slots AvailabilitySlot[]

  @@index([firmId])
  @@index([date])
}

model AvailabilitySlot {
  id        String    @id @default(cuid())
  startAt   DateTime
  endAt     DateTime
  isBooked  Boolean   @default(false)
  isActive  Boolean   @default(true)
  bookedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  firmId String
  firm   LawFirm @relation(fields: [firmId], references: [id], onDelete: Cascade)

  windowId String
  window   AvailabilityWindow @relation(fields: [windowId], references: [id], onDelete: Cascade)

  appointment Appointment?

  @@unique([windowId, startAt])
  @@index([firmId])
  @@index([windowId])
  @@index([startAt])
}

model PaymentGatewayConfig {
  id                  String   @id @default(cuid())
  firmId              String   @unique
  provider            String
  accessTokenEnc      String
  publicKeyEnc        String?
  isActive            Boolean  @default(false)
  enabledBySuperadmin Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  firm LawFirm @relation(fields: [firmId], references: [id], onDelete: Cascade)

  @@index([firmId])
}

model PublicSitePaymentConfig {
  id             String   @id @default("global-public-payment")
  provider       String   @default("MERCADO_PAGO")
  accessTokenEnc String
  publicKeyEnc   String?
  isActive       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Charge {
  id              String  @id @default(cuid())
  firmId          String
  clientId        String
  processId       String?
  createdByUserId String

  provider             String
  providerPreferenceId String?
  providerPaymentId    String?
  externalReference    String  @unique

  amount  Decimal
  dueDate DateTime?
  message String?
  status  String    @default("PENDING")

  paymentUrl       String?
  initPoint        String?
  sandboxInitPoint String?

  emailTarget String?
  phoneTarget String?

  emailSentAt        DateTime?
  whatsappPreparedAt DateTime?
  paidAt             DateTime?
  lastWebhookAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  firm          LawFirm       @relation(fields: [firmId], references: [id], onDelete: Cascade)
  client        Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  process       LegalProcess? @relation(fields: [processId], references: [id], onDelete: SetNull)
  createdByUser User          @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@index([firmId, status])
  @@index([clientId])
  @@index([processId])
  @@index([createdByUserId])
}

model RecurringCharge {
  id                          String   @id @default(cuid())
  firmId                      String
  clientId                    String
  createdByUserId             String
  description                 String
  baseAmount                  Float
  installments                Int
  currentInstallment          Int      @default(0)
  chargeDay                   Int
  hasInterest                 Boolean  @default(false)
  interestPercent             Float?
  interestStartsAtInstallment Int?
  status                      String   @default("ACTIVE")
  nextChargeDate              DateTime
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  firm                  LawFirm                      @relation("FirmRecurringCharges", fields: [firmId], references: [id], onDelete: Cascade)
  client                Client                       @relation("ClientRecurringCharges", fields: [clientId], references: [id], onDelete: Cascade)
  createdByUser         User                         @relation("UserCreatedRecurringCharges", fields: [createdByUserId], references: [id], onDelete: Restrict)
  installmentsGenerated RecurringChargeInstallment[]

  @@index([firmId, status])
  @@index([clientId])
}

model RecurringChargeInstallment {
  id                   String    @id @default(cuid())
  recurringChargeId    String
  installmentNumber    Int
  amount               Float
  dueDate              DateTime
  status               String    @default("PENDING")
  mercadoPagoPaymentId String?
  mercadoPagoInitPoint String?
  emailSentAt          DateTime?
  paidAt               DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  recurringCharge RecurringCharge @relation(fields: [recurringChargeId], references: [id], onDelete: Cascade)

  @@unique([recurringChargeId, installmentNumber])
  @@index([status, dueDate])
}

model LandingPageConfig {
  id                      String   @id @default("global-public-site")
  brandName               String   @default("JURIDICVAS")
  heroTitle               String   @default("Gestão jurí­dica premium para escritórios que querem crescer com organização.")
  heroSubtitle            String   @default("Centralize clientes, processos, prazos, agendamentos e cobranças em uma plataforma moderna, profissional e acessí­vel.")
  heroPrimaryButtonText   String   @default("Entrar")
  heroSecondaryButtonText String   @default("Acompanhar")
  aboutTitle              String   @default("Sobre o sistema")
  aboutText               String   @default("O JURIDICVAS foi criado para profissionalizar a operação jurí­dica com mais controle, imagem profissional e praticidade no dia a dia.")
  featuresTitle           String   @default("Funcionalidades")
  featuresSubtitle        String   @default("Tudo o que seu escritório precisa para operar com segurança e organização.")
  mediaTitle              String   @default("Veja o sistema em ação")
  mediaSubtitle           String   @default("")
  plansTitle              String   @default("Planos")
  plansSubtitle           String   @default("Escolha o plano ideal para o seu momento.")
  updatesTitle            String   @default("Atualizações")
  updatesSubtitle         String   @default("Acompanhe novidades, melhorias e lançamentos do sistema.")
  ctaTitle                String   @default("Pronto para elevar o ní­vel da sua operação jurí­dica?")
  ctaSubtitle             String   @default("Entre agora ou acompanhe seu processo em um ambiente moderno, seguro e profissional.")
  footerText              String   @default("JURIDICVAS - Plataforma jurí­dica premium.")
  loginUrl                String   @default("/login")
  trackUrl                String   @default("/acompanhar")
  isPublished             Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model LandingFeature {
  id          String   @id @default(cuid())
  title       String
  description String
  icon        String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sortOrder])
  @@index([isActive])
}

model LandingMedia {
  id          String   @id @default(cuid())
  title       String
  description String?
  type        String   @default("image")
  url         String
  alt         String?
  section     String   @default("hero")
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([section, sortOrder])
  @@index([isActive])
}

model PublicPlan {
  id                 String   @id @default(cuid())
  name               String
  priceLabel         String
  billingPeriod      String   @default("/mÃƒÆ’Ã‚Âªs")
  description        String?
  featuresText       String
  badgeText          String?
  imageUrl           String?
  imageAlt           String?
  ctaText            String   @default("Assinar agora")
  isPurchasable      Boolean  @default(true)
  moduleDashboard    Boolean  @default(true)
  moduleClients      Boolean  @default(true)
  moduleProcesses    Boolean  @default(true)
  moduleDeadlines    Boolean  @default(true)
  moduleAppointments Boolean  @default(true)
  moduleAvailability Boolean  @default(true)
  moduleUsers        Boolean  @default(true)
  moduleCharges      Boolean  @default(true)
  isHighlighted      Boolean  @default(false)
  sortOrder          Int      @default(0)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  subscriptions   SaaSSubscription[]
  selectedByUsers User[]             @relation("UserSelectedPlan")

  @@index([sortOrder])
  @@index([isActive])
}

model PublicUpdatePost {
  id            String   @id @default(cuid())
  title         String
  summary       String
  category      String   @default("Novidade")
  publishedAt   DateTime @default(now())
  isPublished   Boolean  @default(true)
  isHighlighted Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([publishedAt])
  @@index([isPublished])
}

model SaaSSubscription {
  id                   String    @id @default(cuid())
  userId               String
  publicPlanId         String
  status               String    @default("PENDING")
  provider             String    @default("MERCADO_PAGO")
  providerPreferenceId String?
  providerPaymentId    String?
  externalReference    String    @unique
  checkoutUrl          String?
  paidAt               DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  publicPlan PublicPlan @relation(fields: [publicPlanId], references: [id], onDelete: Restrict)

  @@index([userId, status])
  @@index([publicPlanId])
}
