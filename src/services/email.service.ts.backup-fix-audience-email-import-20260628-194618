  if (recipients.length === 0) {
    return { ok: true, skipped: true };
  }

  const transporter = await getTransporter();

  const actionTitle = input.action === "atualizado" ? "Prazo atualizado" : "Novo prazo cadastrado";
  const subject = `${actionTitle} — ${input.processNumber || "JuridicVas"}`;

  const text = [
    `Advocacia: ${input.firmName}`,
    `Prazo: ${input.title}`,
    `Cliente: ${input.clientName || "Não informado"}`,
    `Processo/CNJ: ${input.processNumber || "Não informado"}`,
    `Tribunal: ${input.tribunal || "Não informado"}`,
    `Vara: ${input.vara || "Não informado"}`,
    `Data/Hora do prazo: ${formatDate(input.dueDate)}`,
    `${input.action === "atualizado" ? "Atualizado" : "Cadastrado"} por: ${input.createdByName}`,
    input.description ? `Descrição/Observações: ${input.description}` : null,
  ]
    .filter(Boolean)
    .join("\n");

  const html = renderPremiumHtml({
    badge: "Prazo",
    title: actionTitle,
    subtitle: "Um prazo processual foi registrado no sistema e todos os usuários ativos da firma estão sendo notificados.",
    rows: [
      { label: "Advocacia", value: input.firmName },
      { label: "Prazo", value: input.title },
      { label: "Cliente", value: input.clientName || "Não informado" },
      { label: "Processo/CNJ", value: input.processNumber || "Não informado" },
      { label: "Tribunal", value: input.tribunal || "Não informado" },
      { label: "Vara", value: input.vara || "Não informado" },
      { label: "Data/Hora do prazo", value: formatDate(input.dueDate) },
      {
        label: input.action === "atualizado" ? "Atualizado por" : "Cadastrado por",
        value: input.createdByName,
      },
      { label: "Descrição/Observações", value: input.description || "" },
    ],
  });

  await transporter.sendMail({
    from: getFrom(),
    to: recipients.join(", "),
    subject,
    text,
    html,
  });

  return { ok: true };
}

