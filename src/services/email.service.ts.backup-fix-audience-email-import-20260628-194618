import nodemailer from "nodemailer";

type AppointmentEmailInput = {
  recipients: string[];
  firmName: string;
  clientName: string;
  scheduledAt: Date;
  durationMinutes: number;
  createdByName: string;
  notes?: string | null;
};

type AudienceEmailInput = {
  recipients: string[];
  firmName: string;
  title: string;
  clientName: string;
  scheduledAt: Date;
  durationMinutes: number;
  createdByName: string;
  notes?: string | null;
  processNumber?: string | null;
  tribunal?: string | null;
  vara?: string | null;
};

type AppointmentCancelledEmailInput = {
  recipients: string[];
  firmName: string;
  clientName: string;
  scheduledAt: Date;
  cancelledByName: string;
  cancelReason: string;
};

type DeadlineEmailInput = {
  recipients: string[];
  firmName: string;
  action: "criado" | "atualizado";
  title: string;
  dueDate: Date;
  createdByName: string;
  description?: string | null;
  clientName?: string | null;
  processNumber?: string | null;
  tribunal?: string | null;
  vara?: string | null;
};

type VerificationEmailInput = {
  to: string;
  name: string;
  token: string;
};

let transporterPromise: Promise<nodemailer.Transporter> | null = null;

async function getTransporter() {
  if (!transporterPromise) {
    transporterPromise = Promise.resolve(
      nodemailer.createTransport({
        host: process.env.SMTP_HOST,
        port: Number(process.env.SMTP_PORT || 587),
        secure: String(process.env.SMTP_SECURE || "false") === "true",
        auth:
          process.env.SMTP_USER && process.env.SMTP_PASS
            ? {
                user: process.env.SMTP_USER,
                pass: process.env.SMTP_PASS,
              }
            : undefined,
      })
    );
  }

  return transporterPromise;
}

function uniqueRecipients(recipients: string[]) {
  return Array.from(
    new Set(
      recipients
        .map((email) => String(email || "").trim().toLowerCase())
        .filter(Boolean)
    )
  );
}

function getFrom() {
  return process.env.SMTP_FROM || "JuridicVas <no-reply@localhost>";
}

function getBaseUrl() {
  return process.env.APP_BASE_URL?.trim() || "http://localhost:3000";
}

function formatDate(dt: Date) {
  return new Intl.DateTimeFormat("pt-BR", {
    dateStyle: "full",
    timeStyle: "short",
    timeZone: "America/Sao_Paulo",
  }).format(dt);
}

function escapeHtml(value: string | null | undefined) {
  return String(value || "")
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;");
}

function renderPremiumHtml(params: {
  badge: string;
  title: string;
  subtitle: string;
  rows: Array<{ label: string; value?: string | null }>;
  footer?: string;
}) {
  const rows = params.rows
    .filter((row) => String(row.value || "").trim())
    .map(
      (row) => `
        <tr>
          <td style="padding:12px 14px; color:#94a3b8; border-bottom:1px solid rgba(148,163,184,0.16); width:180px; font-size:13px;">
            ${escapeHtml(row.label)}
          </td>
          <td style="padding:12px 14px; color:#f8fafc; border-bottom:1px solid rgba(148,163,184,0.16); font-size:14px; font-weight:700;">
            ${escapeHtml(row.value)}
          </td>
        </tr>
      `
    )
    .join("");

  return `
    <div style="margin:0; padding:28px; background:#070b18; color:#e2e8f0; font-family:Arial, Helvetica, sans-serif;">
      <div style="max-width:720px; margin:0 auto;">
        <div style="border-radius:24px; overflow:hidden; border:1px solid rgba(168,85,247,0.28); background:#0f172a; box-shadow:0 24px 70px rgba(0,0,0,0.28);">
          <div style="padding:26px 28px; background:linear-gradient(135deg,#111827,#312e81); border-bottom:1px solid rgba(255,255,255,0.08);">
            <div style="font-size:12px; letter-spacing:0.14em; color:#c4b5fd; font-weight:900; text-transform:uppercase;">
              JURIDICVAS · ${escapeHtml(params.badge)}
            </div>
            <h1 style="margin:12px 0 0; color:#ffffff; font-size:28px; line-height:1.2;">
              ${escapeHtml(params.title)}
            </h1>
            <p style="margin:10px 0 0; color:#cbd5e1; line-height:1.7;">
              ${escapeHtml(params.subtitle)}
            </p>
          </div>

          <div style="padding:24px 28px;">
            <table style="width:100%; border-collapse:collapse; background:rgba(15,23,42,0.72); border:1px solid rgba(148,163,184,0.16); border-radius:16px; overflow:hidden;">
              ${rows}
            </table>

            ${
              params.footer
                ? `<p style="margin:22px 0 0; color:#94a3b8; line-height:1.7; font-size:13px;">${escapeHtml(params.footer)}</p>`
                : ""
            }
          </div>
        </div>

        <p style="margin:16px 0 0; color:#64748b; font-size:12px; text-align:center;">
          Esta é uma notificação automática do JuridicVas.
        </p>
      </div>
    </div>
  `;
}

export async function sendAppointmentNotificationToFirmMasters(
  input: AppointmentEmailInput
) {
  const recipients = uniqueRecipients(input.recipients);

  if (recipients.length === 0) {
    return { ok: true, skipped: true };
  }

  const transporter = await getTransporter();

  const subject = "Novo agendamento criado — JuridicVas";
  const text = [
    `Advocacia: ${input.firmName}`,
    `Cliente: ${input.clientName}`,
    `Data/Hora: ${formatDate(input.scheduledAt)}`,
    `Duração: ${input.durationMinutes} minuto(s)`,
    `Criado por: ${input.createdByName}`,
    input.notes ? `Observações: ${input.notes}` : null,
  ]
    .filter(Boolean)
    .join("\n");

  const html = renderPremiumHtml({
    badge: "Agendamento",
    title: "Novo agendamento criado",
    subtitle: "Um novo atendimento foi cadastrado no sistema.",
    rows: [
      { label: "Advocacia", value: input.firmName },
      { label: "Cliente", value: input.clientName },
      { label: "Data/Hora", value: formatDate(input.scheduledAt) },
      { label: "Duração", value: `${input.durationMinutes} minuto(s)` },
      { label: "Criado por", value: input.createdByName },
      { label: "Observações", value: input.notes || "" },
    ],
  });

  await transporter.sendMail({
    from: getFrom(),
    to: recipients.join(", "),
    subject,
    text,
    html,
  });

  return { ok: true };
}

