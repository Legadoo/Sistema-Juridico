import { NextResponse } from "next/server";
import { ensureAdminModuleResponse } from "@/lib/admin/moduleAccess";
import bcrypt from "bcryptjs";
import { prisma } from "@/lib/prisma";
import { getSessionUser } from "@/lib/session";

function canManageUsers(role: string) {
  return role === "MASTER";
}

function normalizeRole(role: string) {
  const value = role.trim().toUpperCase();

  if (value === "MASTER") return "MASTER";
  if (value === "SECRETARY") return "SECRETARY";

  return "";
}

export async function POST(req: Request) {
  const moduleGuard = await ensureAdminModuleResponse("moduleUsers");
  if (moduleGuard) return moduleGuard;

  const actor = await getSessionUser();

  if (!actor) {
    return NextResponse.json(
      { ok: false, message: "Não autenticado." },
      { status: 401 }
    );
  }

  if (!canManageUsers(actor.role)) {
    return NextResponse.json(
      { ok: false, message: "Somente advogado pode editar usuários." },
      { status: 403 }
    );
  }

  if (!actor.firmId) {
    return NextResponse.json(
      { ok: false, message: "Usuário sem advocacia vinculada." },
      { status: 403 }
    );
  }

  const body = await req.json().catch(() => null);

  const userId = (body?.userId ?? "").toString().trim();
  const name = (body?.name ?? "").toString().trim();
  const email = (body?.email ?? "").toString().trim().toLowerCase();
  const phone = (body?.phone ?? "").toString().trim();
  const password = (body?.password ?? "").toString();
  const role = normalizeRole((body?.role ?? "").toString());

  if (!userId) {
    return NextResponse.json(
      { ok: false, message: "userId obrigatório." },
      { status: 400 }
    );
  }

  if (!name || !email) {
    return NextResponse.json(
      { ok: false, message: "Preencha nome e e-mail." },
      { status: 400 }
    );
  }

  if (!role) {
    return NextResponse.json(
      { ok: false, message: "Perfil inválido." },
      { status: 400 }
    );
  }

  const target = await prisma.user.findFirst({
    where: {
      id: userId,
      firmId: actor.firmId,
      role: {
        in: ["MASTER", "SECRETARY"],
      },
    },
  });

  if (!target) {
    return NextResponse.json(
      { ok: false, message: "Usuário não encontrado nesta advocacia." },
      { status: 404 }
    );
  }

  if (target.role === "SUPERADMIN") {
    return NextResponse.json(
      { ok: false, message: "Não é permitido alterar SUPERADMIN por esta tela." },
      { status: 403 }
    );
  }

  if (email !== target.email) {
    const exists = await prisma.user.findFirst({
      where: {
        email,
        NOT: {
          id: userId,
        },
      },
      select: {
        id: true,
      },
    });

    if (exists) {
      return NextResponse.json(
        { ok: false, message: "E-mail já está em uso." },
        { status: 400 }
      );
    }
  }

  const data: Record<string, unknown> = {
    name,
    email,
    phone: phone || null,
    role,
    emailVerified: true,
    emailVerifiedAt: target.emailVerifiedAt ?? new Date(),
    onboardingStatus: "ACTIVE",
    selectedPlanId: null,
    selectedPlanNameSnapshot: null,
  };

  if (password) {
    data.password = await bcrypt.hash(password, 10);
  }

  const updated = await prisma.user.update({
    where: { id: userId },
    data,
    select: {
      id: true,
      name: true,
      email: true,
      phone: true,
      role: true,
      active: true,
      createdAt: true,
      updatedAt: true,
    },
  });

  return NextResponse.json({
    ok: true,
    user: updated,
    message: "Usuário atualizado com sucesso.",
  });
}