          .jv-client-card {
            display: grid;
            grid-template-columns: minmax(260px, 1fr) auto;
            gap: 18px;
            align-items: center;
            padding: 18px;
            border-radius: 22px;
            border: 1px solid rgba(148,163,184,0.13);
            background: rgba(255,255,255,0.035);
          }

          .jv-client-name {
            color: #f8fafc;
            font-size: 19px;
            font-weight: 950;
          }

          .jv-client-meta {
            margin-top: 8px;
            color: #cbd5e1;
            font-size: 14px;
          }

          .jv-client-muted {
            margin-top: 7px;
            color: #94a3b8;
            font-size: 13px;
          }

          .jv-client-pills {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-top: 12px;
          }

          .jv-pill {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            padding: 8px 11px;
            border-radius: 999px;
            font-size: 12px;
            font-weight: 900;
          }

          .jv-pill-purple {
            color: #ddd6fe;
            background: rgba(124,58,237,0.13);
            border: 1px solid rgba(168,85,247,0.24);
          }

          .jv-pill-blue {
            color: #bfdbfe;
            background: rgba(59,130,246,0.13);
            border: 1px solid rgba(96,165,250,0.24);
          }

          .jv-pill-green {
            color: #a7f3d0;
            background: rgba(6,78,59,0.18);
            border: 1px solid rgba(52,211,153,0.24);
          }

          .jv-pill-red {
            color: #fecaca;
            background: rgba(127,29,29,0.18);
            border: 1px solid rgba(248,113,113,0.24);
          }

          .jv-client-actions {
            display: flex;
            flex-wrap: wrap;
            gap: 9px;
            justify-content: flex-end;
          }

          .jv-empty {
            padding: 20px;
            border-radius: 18px;
            background: rgba(255,255,255,0.035);
            border: 1px dashed rgba(148,163,184,0.22);
            color: #94a3b8;
            text-align: center;
          }

          @media (max-width: 1100px) {
            .jv-stats-grid {
              grid-template-columns: 1fr;
            }

            .jv-filters {
              grid-template-columns: 1fr;
            }

            .jv-client-card {
              grid-template-columns: 1fr;
            }

            .jv-client-actions {
              justify-content: flex-start;
            }
          }

          @media (max-width: 640px) {
            .jv-clients-hero {
              padding: 28px 22px;
              min-height: auto;
            }

            .jv-clients-hero::before {
              display: none;
            }

            .jv-client-primary,
            .jv-client-secondary,
            .jv-client-danger,
            .jv-client-success {
              width: 100%;
            }

            .jv-client-actions {
              display: grid;
            }

            .jv-mode-tabs {
              display: grid;
              grid-template-columns: 1fr;
            }
          }
        `}</style>

        <section className="jv-clients-hero">
          <div className="jv-clients-hero-content">
            <div>
              <div className="jv-kicker">Gestão de clientes</div>

              <h1 className="jv-title">Clientes</h1>

              <p className="jv-subtitle">
                Cadastre, pesquise, edite, arquive e gere acesso seguro para o
                portal de acompanhamento.
              </p>
            </div>

            <button className="jv-client-primary" onClick={openCreateModal}>
              Novo cliente
            </button>
          </div>
        </section>

        <section className="jv-stats-grid">
          <ClientStatCard
            title="Clientes na visualização"
            value={stats.total}
            subtitle={listMode === "active" ? "Ativos" : listMode === "archived" ? "Arquivados" : "Todos"}
            Icon={FaUserGroup}
          />

          <ClientStatCard
            title="Com e-mail"
            value={stats.withEmail}
            subtitle="Clientes com e-mail cadastrado"
            Icon={FaEnvelope}
          />

          <ClientStatCard
            title="Com telefone"
            value={stats.withPhone}
            subtitle="Clientes com telefone cadastrado"
            Icon={FaPhone}
          />
        </section>

        <section className="jv-client-panel">
          <div className="jv-panel-head">
            <div>
              <div className="jv-panel-title">Lista de clientes</div>
              <div className="jv-panel-subtitle">
                Busque por nome, CPF/CNPJ, telefone, e-mail, código ou processo.
              </div>
            </div>
          </div>

          <div className="jv-filters">
            <label className="jv-search-box">
              <FaMagnifyingGlass />
              <input
                value={search}
                onChange={(event) => setSearch(event.target.value)}
                placeholder="Buscar cliente, CPF, processo, código..."
              />
              {search ? (
                <button
                  type="button"
                  onClick={() => setSearch("")}
                  style={{
                    border: 0,
                    background: "transparent",
                    color: "#CBD5E1",
                    cursor: "pointer",
                  }}
                >
                  <FaXmark />
                </button>
              ) : null}
            </label>

            <div className="jv-mode-tabs">
              <button
                type="button"
                className={listMode === "active" ? "jv-mode-tab jv-mode-tab-active" : "jv-mode-tab"}
                onClick={() => void changeListMode("active")}
              >
                Ativos
              </button>

              <button
                type="button"
                className={listMode === "archived" ? "jv-mode-tab jv-mode-tab-active" : "jv-mode-tab"}
                onClick={() => void changeListMode("archived")}
              >
                Arquivados
              </button>

              <button
                type="button"
                className={listMode === "all" ? "jv-mode-tab jv-mode-tab-active" : "jv-mode-tab"}
                onClick={() => void changeListMode("all")}
              >
                Todos
              </button>
            </div>
          </div>

          {loading ? (
            <div className="jv-empty">Carregando clientes...</div>
          ) : filteredClients.length === 0 ? (
            <div className="jv-empty">
              Nenhum cliente encontrado para o filtro atual.
            </div>
          ) : (
            <div className="jv-client-list">
              {filteredClients.map((client) => (
                <article className="jv-client-card" key={client.id}>
                  <div>
                    <div className="jv-client-name">{client.name}</div>

                    <div className="jv-client-meta">
                      {formatDocument(client.document)}
                    </div>

                    <div className="jv-client-muted">
                      {[client.phone ? formatPhone(client.phone) : "", client.email]
                        .filter(Boolean)
                        .join(" · ") || "Sem telefone e e-mail cadastrados"}
                    </div>

                    <div className="jv-client-pills">
                      <span className="jv-pill jv-pill-purple">
                        Código: {client.accessCode}
                      </span>

                      <span className="jv-pill jv-pill-blue">
                        Criado em {formatDate(client.createdAt)}
                      </span>

                      <span className={client.archived ? "jv-pill jv-pill-red" : "jv-pill jv-pill-green"}>
                        {client.archived ? "Arquivado" : "Ativo"}
                      </span>

                      {(client.processes || []).slice(0, 2).map((process) => (
                        <span className="jv-pill jv-pill-blue" key={process.id}>
                          Processo: {process.cnj}
                        </span>
                      ))}
                    </div>
                  </div>

                  <div className="jv-client-actions">
                    <button
                      className="jv-client-secondary"
                      onClick={() => copyWhatsapp(client)}
                    >
                      <FaCopy />
                      Copiar acesso
                    </button>

                    {canArchive && !client.archived ? (
                      <button
                        className="jv-client-danger"
                        onClick={() => setActionModal({ type: "archive", client })}
                      >
                        <FaArchive />
                        Arquivar
                      </button>
                    ) : null}

                    {canArchive && client.archived ? (
                      <button
                        className="jv-client-success"
                        onClick={() => setActionModal({ type: "unarchive", client })}
                      >
                        <FaRotateLeft />
                        Desarquivar
                      </button>
                    ) : null}

                    {canEdit ? (
                      <button
                        className="jv-client-secondary"
                        onClick={() => openEditModal(client)}
                      >
                        <FaPenToSquare />
                        Editar
                      </button>
                    ) : null}
                  </div>
                </article>
              ))}
            </div>
          )}
        </section>
      </div>
    </AdminShell>
  );
}