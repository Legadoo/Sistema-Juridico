type MeResponse = {
  ok?: boolean;
  user?: {
    id?: string;
    name?: string;
    role?: string;
  };
};

type Me = {
  id: string;
  name: string;
  role: string;
};

type UserRole = "MASTER" | "SECRETARY";

type UserRow = {
  id: string;
  name: string;
  email: string;
  phone?: string | null;
  role?: UserRole;
  active: boolean;
  createdAt?: string;
};

type ToastState = {
  open: boolean;
  message: string;
  type: "success" | "error" | "warning" | "info";
};

type FormState = {
  name: string;
  email: string;
  phone: string;
  password: string;
  role?: UserRole;
};

type StatusAction = {
  user: UserRow;
} | null;

const emptyForm: FormState = {
  name: "",
  email: "",
  phone: "",
  password: "",
  role: "SECRETARY",
};

function normalizeMe(data: MeResponse): Me | null {
  if (!data?.ok || !data?.user) return null;

  return {
    id: data.user.id ?? "",
    name: data.user.name ?? "Usuário",
    role: data.user.role ?? "SECRETARY",
  };
}

function normalizeText(value: string) {
  return (value || "")
    .toLowerCase()
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "");
}

function onlyDigits(value: string) {
  return (value || "").replace(/\D/g, "");
}

function formatPhone(value: string) {
  const digits = onlyDigits(value).slice(0, 11);

  if (digits.length <= 10) {
    return digits
      .replace(/^(\d{2})(\d)/, "($1) $2")
      .replace(/(\d{4})(\d)/, "$1-$2");
  }

  return digits
    .replace(/^(\d{2})(\d)/, "($1) $2")
    .replace(/(\d{5})(\d)/, "$1-$2");
}

function formatDate(date?: string) {
  if (!date) return "Sem data";

  try {
    return new Date(date).toLocaleDateString("pt-BR");
  } catch {
    return date;
  }
}

function roleLabel(role: string) {
  if (role === "MASTER") return "Advogado";
  if (role === "SECRETARY") return "Secretária";
  return role;
}

