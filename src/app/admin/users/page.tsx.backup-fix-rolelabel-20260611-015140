        formMode === "create"
          ? "Secretária criada com sucesso."
          : "Acesso da secretária atualizado com sucesso.",
        "success"
      );
    } catch {
      showToast("Não foi possível salvar o usuário.", "error");
    } finally {
      setSaving(false);
    }
  }

