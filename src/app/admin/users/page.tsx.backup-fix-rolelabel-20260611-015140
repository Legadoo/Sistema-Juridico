            display: grid;
            gap: 8px;
            padding: 16px;
            border-radius: 18px;
            background: rgba(255,255,255,0.035);
            border: 1px solid rgba(148,163,184,0.16);
            color: #e2e8f0;
          }

          .jv-confirm-box strong {
            color: #f8fafc;
          }

          .jv-confirm-box span {
            color: #94a3b8;
          }

          @media (max-width: 1100px) {
            .jv-stats-grid,
            .jv-filters {
              grid-template-columns: 1fr;
            }

            .jv-user-card {
              grid-template-columns: 1fr;
            }

            .jv-actions {
              justify-content: flex-start;
            }
          }

          @media (max-width: 640px) {
            .jv-hero {
              padding: 28px 22px;
              min-height: auto;
            }

            .jv-primary,
            .jv-secondary,
            .jv-danger,
            .jv-success {
              width: 100%;
            }

            .jv-actions {
              display: grid;
            }

            .jv-mode-tabs {
              display: grid;
              grid-template-columns: 1fr;
            }
          }
        `}</style>

        <section className="jv-hero">
          <div className="jv-hero-content">
            <div>
              <div className="jv-kicker">Gestão de usuários</div>

              <h1 className="jv-title">Usuários</h1>

              <p className="jv-subtitle">
                Controle as contas internas da advocacia. O advogado visualiza todos, cria secretárias e gerencia apenas e-mail, senha e acesso das secretárias.
              </p>
            </div>

            {canManage ? (
              <button className="jv-primary" onClick={openCreateModal}>
                <FaPlus />
                Nova secretária
              </button>
            ) : null}
          </div>
        </section>

        {!canManage ? (
          <section className="jv-panel">
            <div className="jv-access-denied">
              <strong>Acesso restrito ao advogado</strong>
              Esta aba é exclusiva para gestão interna da advocacia. Secretárias não possuem acesso a este módulo.
            </div>
          </section>
        ) : (
          <>
            <section className="jv-stats-grid">
              <article className="jv-stat-card">
                <div className="jv-stat-icon">
                  <FaUserGroup />
                </div>
                <div>
                  <div className="jv-stat-title">Usuários totais</div>
                  <div className="jv-stat-value">{stats.total}</div>
                  <div className="jv-stat-subtitle">Contas internas</div>
                </div>
              </article>

              <article className="jv-stat-card">
                <div className="jv-stat-icon">
                  <FaCircleCheck />
                </div>
                <div>
                  <div className="jv-stat-title">Ativos</div>
                  <div className="jv-stat-value">{stats.active}</div>
                  <div className="jv-stat-subtitle">Com acesso liberado</div>
                </div>
              </article>

              <article className="jv-stat-card">
                <div className="jv-stat-icon">
                  <FaUserLock />
                </div>
                <div>
                  <div className="jv-stat-title">Inativos</div>
                  <div className="jv-stat-value">{stats.inactive}</div>
                  <div className="jv-stat-subtitle">Acesso bloqueado</div>
                </div>
              </article>
            </section>

            <section className="jv-panel">
              <div className="jv-panel-title">Lista de usuários</div>
              <div className="jv-panel-subtitle">
                Busque por nome, e-mail, telefone ou perfil. Advogados aparecem apenas para visualização.
              </div>

              <div className="jv-filters">
                <label className="jv-search-box">
                  <FaMagnifyingGlass />
                  <input
                    value={search}
                    onChange={(event) => setSearch(event.target.value)}
                    placeholder="Buscar usuário, e-mail, telefone..."
                  />
                  {search ? (
                    <button
                      type="button"
                      onClick={() => setSearch("")}
                      style={{
                        border: 0,
                        background: "transparent",
                        color: "#CBD5E1",
                        cursor: "pointer",
                      }}
                    >
                      <FaXmark />
                    </button>
                  ) : null}
                </label>

                <div className="jv-mode-tabs">
                  <button
                    className={statusFilter === "active" ? "jv-mode-tab jv-mode-tab-active" : "jv-mode-tab"}
                    onClick={() => setStatusFilter("active")}
                  >
                    Ativos
                  </button>

                  <button
                    className={statusFilter === "inactive" ? "jv-mode-tab jv-mode-tab-active" : "jv-mode-tab"}
                    onClick={() => setStatusFilter("inactive")}
                  >
                    Inativos
                  </button>

                  <button
                    className={statusFilter === "all" ? "jv-mode-tab jv-mode-tab-active" : "jv-mode-tab"}
                    onClick={() => setStatusFilter("all")}
                  >
                    Todos
                  </button>
                </div>
              </div>

              {loading ? (
                <div className="jv-empty">Carregando usuários...</div>
              ) : filteredUsers.length === 0 ? (
                <div className="jv-empty">Nenhum usuário encontrado.</div>
              ) : (
                <div className="jv-list">
                  {filteredUsers.map((user) => (
                    <article className="jv-user-card" key={user.id}>
                      <div>
                        <div className="jv-user-name">{user.name}</div>

                        <div className="jv-user-meta">{user.email}</div>

                        <div className="jv-user-muted">
                          Telefone: {user.phone || "Não informado"}
                        </div>

                        <div className="jv-pills">
                          <span className="jv-pill jv-pill-purple">
                            <FaShieldHalved />
                            {roleLabel(user.role)}
                          </span>

                          <span className={user.active ? "jv-pill jv-pill-green" : "jv-pill jv-pill-red"}>
                            {user.active ? "Ativo" : "Inativo"}
                          </span>

                          <span className="jv-pill jv-pill-blue">
                            Criado em {formatDate(user.createdAt)}
                          </span>
                        </div>
                      </div>

                      <div className="jv-actions">
                        {user.role === "SECRETARY" ? (
                          <>
                            <button className="jv-secondary" onClick={() => openEditModal(user)}>
                              <FaPenToSquare />
                              Editar acesso
                            </button>

                            <button
                              className={user.active ? "jv-danger" : "jv-success"}
                              onClick={() => setStatusAction({ user })}
                            >
                              <FaUserGear />
                              {user.active ? "Desativar acesso" : "Ativar acesso"}
                            </button>
                          </>
                        ) : (
                          <span className="jv-readonly-pill">
                            Advogado principal
                          </span>
                        )}
                      </div>
                    </article>
                  ))}
                </div>
              )}
            </section>
          </>
        )}
      </div>
    </AdminShell>
  );
}