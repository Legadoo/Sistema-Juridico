    setFormMode("create");
    setEditingId(null);
    setForm(emptyForm);
    setFormOpen(true);
  }

  function openEditModal(user: UserRow) {
    if (user.role !== "SECRETARY") {
      showToast("O advogado só pode editar acesso de secretárias.", "warning");
      return;
    }

    setFormMode("edit");
    setEditingId(user.id);
    setForm({
      name: user.name,
      email: user.email,
      phone: user.phone || "",
      password: "",
      role: "SECRETARY",
    });
    setFormOpen(true);
  }

  async function submitForm() {
    const payload = {
      userId: editingId,
      name: form.name.trim(),
      email: form.email.trim(),
      phone: form.phone.trim(),
      password: form.password,
      role: "SECRETARY",
    };

    if (formMode === "create" && (!payload.name || !payload.email || !payload.password)) {
      showToast("Preencha nome, e-mail e senha inicial.", "warning");
      return;
    }

    if (formMode === "edit" && !payload.email && !payload.password) {
      showToast("Informe novo e-mail ou nova senha.", "warning");
      return;
    }

    setSaving(true);

    try {
      const endpoint =
        formMode === "create" ? "/api/admin/users" : "/api/admin/users/update";

      const body =
        formMode === "create"
          ? {
              name: form.name.trim(),
              email: form.email.trim(),
              phone: form.phone.trim(),
              password: form.password,
              role: "SECRETARY",
            }
          : {
              userId: editingId,
              email: form.email.trim(),
              password: form.password,
            };

      const response = await fetch(endpoint, {
        method: "POST",
        credentials: "include",
        headers: { "content-type": "application/json" },
        body: JSON.stringify(body),
      }).then(async (response) => ({
        ok: response.ok,
        data: await response.json().catch(() => ({})),
      }));

      if (!response.ok || !response.data?.ok) {
        showToast(response.data?.message || "Erro ao salvar usuário.", "error");
        return;
